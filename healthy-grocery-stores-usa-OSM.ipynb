import os
import time
import requests
import pandas as pd
import geopandas as gpd
from shapely.geometry import Point

OVERPASS_URL = "https://overpass-api.de/api/interpreter"

output_folder = r"D:\OSM_Health_Grocery_USA_ALL_V7"
xml_folder = os.path.join(output_folder, "xml_by_state")
shapefile_path = os.path.join(output_folder, "usa_mis_health_grocery3.shp")

sleep_time = 3
timeout = 300
max_retries = 4

os.makedirs(xml_folder, exist_ok=True)

states = [
    "DE","GA","LA","MD","NM","ND","OH","OK","PA","RI"
]


def build_query(state_code):
    shops = [
        "supermarket", "greengrocer", "health_food", "farm",
        "butcher", "seafood", "bakery", "cheese",
        "dairy", "deli", "frozen_food", "nuts",
        "pasta", "spices", "water", "convenience",
        "food", "general"
    ]

    q = f"""
    [out:xml][timeout:300][maxsize:1073741824];
    area["ISO3166-2"="US-{state_code}"][admin_level=4]->.searchArea;
    (
    """

    for s in shops:
        q += f"""
        node["shop"="{s}"](area.searchArea);
        way["shop"="{s}"](area.searchArea);
        relation["shop"="{s}"](area.searchArea);
        """

    #  ADD marketplace
    q += """
        node["amenity"="marketplace"](area.searchArea);
        way["amenity"="marketplace"](area.searchArea);
        relation["amenity"="marketplace"](area.searchArea);
    """

    # organic
    q += """
        node["organic"="yes"](area.searchArea);
        way["organic"="yes"](area.searchArea);
        relation["organic"="yes"](area.searchArea);
    );
    out center;
    """

    return q


def download_xml(state_code):
    query = build_query(state_code)
    path = os.path.join(xml_folder, f"{state_code}.osm")

    for i in range(max_retries):
        try:
            r = requests.post(
                OVERPASS_URL,
                data=query.encode("utf-8"),
                headers={"Content-Type": "text/plain"},
                timeout=timeout
            )

            if r.status_code == 429:
                wait = 10 * (i + 1)
                print(f"{state_code}: rate limited, waiting {wait}s")
                time.sleep(wait)
                continue

            r.raise_for_status()

            with open(path, "wb") as f:
                f.write(r.content)

            print(f"{state_code}: done")
            return path

        except Exception as e:
            wait = 10 * (i + 1)
            print(f"{state_code}: retrying in {wait}s ({e})")
            time.sleep(wait)

    print(f"{state_code}: skipped")
    return None


def parse_xml(path, state_code):
    import xml.etree.ElementTree as ET

    rows = []
    tree = ET.parse(path)
    root = tree.getroot()

    for el in root:
        if el.tag not in ("node", "way", "relation"):
            continue

        lat, lon = None, None

        if el.tag == "node":
            lat = el.attrib.get("lat")
            lon = el.attrib.get("lon")
        else:
            c = el.find("center")
            if c is not None:
                lat = c.attrib.get("lat")
                lon = c.attrib.get("lon")

        if not lat or not lon:
            continue

        tags = {t.attrib["k"]: t.attrib["v"] for t in el.findall("tag")}

        # build full address
        addr_parts = [
            tags.get("addr:housenumber"),
            tags.get("addr:street"),
            tags.get("addr:city"),
            tags.get("addr:state"),
            tags.get("addr:postcode")
        ]
        addr_full = ", ".join([p for p in addr_parts if p])

        rows.append({
            "state": state_code,
            "osm_type": el.tag,
            "osm_id": el.attrib.get("id"),
            "name": tags.get("name"),
            "shop": tags.get("shop"),
            "amenity": tags.get("amenity"),
            "organic": tags.get("organic"),
            "brand": tags.get("brand"),
            "operator": tags.get("operator"),

            "addr_house": tags.get("addr:housenumber"),
            "addr_street": tags.get("addr:street"),
            "addr_city": tags.get("addr:city"),
            "addr_state": tags.get("addr:state"),
            "postcode": tags.get("addr:postcode"),
            "addr_full": addr_full,

            "phone": tags.get("phone"),
            "website": tags.get("website"),
            "opening_hours": tags.get("opening_hours"),

            "lat": float(lat),
            "lon": float(lon)
        })

    return rows


def main():
    all_rows = []

    for s in states:
        xml_file = download_xml(s)
        if not xml_file:
            continue

        data = parse_xml(xml_file, s)
        print(f"{s}: {len(data)} features")

        all_rows.extend(data)
        time.sleep(sleep_time)

    if not all_rows:
        print("no data collected")
        return

    df = pd.DataFrame(all_rows).drop_duplicates(subset=["osm_type", "osm_id"])

    gdf = gpd.GeoDataFrame(
        df,
        geometry=[Point(xy) for xy in zip(df["lon"], df["lat"])],
        crs="EPSG:4326"
    )

    gdf.to_file(shapefile_path)
    print("saved shapefile")


if __name__ == "__main__":
    main()
