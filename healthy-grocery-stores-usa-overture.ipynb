import os
import duckdb
import pandas as pd
import geopandas as gpd
from shapely import wkb

# CONFIGURATION
OUTPUT_FOLDER = r"D:\Overture_Health_Grocery_USA_ALL"
SHAPEFILE_PATH = os.path.join(OUTPUT_FOLDER, "usa_all_grocery_with_coords.shp")
# Create output folder if it doesn't exist
os.makedirs(OUTPUT_FOLDER, exist_ok=True)

# Target categories (food-related places)
TARGET_CATEGORIES = [no i 
    'grocery_store', 'supermarket', 'health_food_store', 
    'bakery', 'butcher_shop', 'seafood_market', 'farmers_market',
    'delicatessen', 'convenience_store'
]

def get_overture_data():
    print("Connecting to Overture via DuckDB...")
    con = duckdb.connect()
    con.execute("SET memory_limit='8GB';") 
    con.execute("INSTALL sapatial; LOAD spatial;")
    con.execute("INSTALL httpfs; LOAD httpfs;")
    con.execute("SET s3_region='us-west-2';")

    print("Detecting latest release version...")
    latest_release = con.execute("SELECT latest FROM 'https://stac.overturemaps.org/catalog.json'").fetchone()[0]
    overture_path = f"s3://overturemaps-us-west-2/release/{latest_release}/theme=places/type=place/*"
    
    categories_str = ", ".join([f"'{c}'" for c in TARGET_CATEGORIES])
    
    # ADDED ST_X and ST_Y to extract coordinates
    query = f"""
    SELECT 
        id,
        names.primary AS name,
        basic_category AS cat_basic,
        taxonomy.primary AS cat_detail,
        addresses[1].freeform AS address,
        addresses[1].locality AS city,
        addresses[1].region AS state,
        addresses[1].postcode AS postcode,
        ST_X(geometry) AS longitude,
        ST_Y(geometry) AS latitude,
        ST_AsWKB(geometry) AS geom_wkb
    FROM read_parquet('{overture_path}')
    WHERE addresses[1].country = 'US'
      AND (
          basic_category IN ({categories_str})
          OR list_contains(taxonomy.alternates, 'organic')
      )
    """
    
    print("Streaming nationwide data (including Lat/Lon)... This will take a few minutes.")
    df = con.execute(query).df()
    return df

def main():
    try:
        df = get_overture_data()
        
        if df.empty:
            print("No data found.")
            return

        print(f"Found {len(df)} records. Converting to GeoDataFrame...")

        gdf = gpd.GeoDataFrame(
            df.drop(columns=['geom_wkb']), 
            geometry=df['geom_wkb'].apply(lambda x: wkb.loads(bytes(x)) if x else None),
            crs="EPSG:4326"
        )

        # Cleanup for Shapefile (10 char limit)
        gdf = gdf.rename(columns={
            'cat_basic': 'basic_cat',
            'cat_detail': 'detail_cat',
            'postcode': 'zip',
            'longitude': 'lon',
            'latitude': 'lat'
        })
        
        # Convert attributes to string for Shapefile driver
        for col in gdf.columns:
            if col not in ['geometry', 'lon', 'lat']:
                gdf[col] = gdf[col].astype(str).replace(['None', 'nan', '<NA>'], '')

        print(f"Saving to {SHAPEFILE_PATH}...")
        gdf.to_file(SHAPEFILE_PATH)
        
        print(f"--- SUCCESS ---")
        print(f"Total Points: {len(gdf)}")
        print(f"Sample Coordinates (First Row): {gdf['lat'].iloc[0]}, {gdf['lon'].iloc[0]}")

    except Exception as e:
        print(f"CRITICAL ERROR: {e}")

if __name__ == "__main__":
    main()
